---
// The floating menu bar pinned to the top of every page.
// "Yael Issacharov" links home; "About" and "Reach Out" go to the About page.
const base = import.meta.env.BASE_URL;
const home = base;
const about = `${base}/about`.replace(/\/{2,}/g, '/');
const reachOut = `${about}#reach-out`;
---

<header class="nav">
  <div class="nav__pill">
    <a class="nav__company" href={home}>Yael Issacharov</a>
    <nav class="nav__links" aria-label="Primary">
      <a class="nav__link" href={about}>About</a>
      <a class="nav__button" href={reachOut}>Reach Out</a>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-header);
    display: flex;
    justify-content: center;
    padding: var(--header-pad-y) var(--header-pad-x);
    pointer-events: none; /* let clicks pass except on the pill itself */
  }

  .nav__pill {
    pointer-events: auto;
    width: 100%;
    max-width: calc(var(--container-max) - 2 * var(--header-pad-x));
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    background: var(--color-header-bg);
    border-radius: var(--radius-pill);
    padding: 8px 8px 8px 16px;
    -webkit-backdrop-filter: blur(var(--header-blur));
    backdrop-filter: blur(var(--header-blur));
  }

  .nav__company {
    font-family: var(--font-display);
    font-size: var(--company-size);
    line-height: var(--company-line);
    letter-spacing: var(--company-tracking);
    color: var(--color-on-dark);
    white-space: nowrap;
  }

  .nav__links {
    display: flex;
    align-items: center;
    gap: var(--nav-gap);
  }

  .nav__link {
    font-family: var(--font-body);
    font-size: var(--nav-size);
    letter-spacing: var(--nav-tracking);
    font-weight: 500;
    color: var(--color-on-dark);
    white-space: nowrap;
  }

  .nav__button {
    font-family: var(--font-body);
    font-size: var(--nav-size);
    letter-spacing: var(--nav-tracking);
    font-weight: 500;
    color: var(--color-button-text);
    background: var(--color-button-bg);
    border-radius: var(--radius-button);
    padding: 8px 12px;
    white-space: nowrap;
  }
</style>
