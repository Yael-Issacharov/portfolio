---
// A single project on the home gallery: cover image, then the meta row
// (studio / role / years), then the title with discipline chips.
// The whole card links to the project page. `featured` cards span the full
// grid width on desktop.
import { Image } from 'astro:assets';
import ProjectMeta from './ProjectMeta.astro';

interface Props {
  slug: string;
  title: string;
  disciplines: string[];
  studio: string;
  role: string;
  years: string;
  thumbnail?: ImageMetadata;
  featured?: boolean;
}
const { slug, title, disciplines, studio, role, years, thumbnail, featured = false } =
  Astro.props;

const base = import.meta.env.BASE_URL;
const href = `${base}/projects/${slug}`.replace(/\/{2,}/g, '/');
---

<a class:list={['card', { 'card--featured': featured }]} href={href}>
  <div class="card__image">
    {
      thumbnail ? (
        <Image
          src={thumbnail}
          alt={`${title} — project cover`}
          widths={[520, 800, 1080, 1600]}
          sizes="(max-width: 767px) 90vw, (max-width: 1023px) 700px, 1080px"
          loading="lazy"
        />
      ) : (
        <div class="card__placeholder" aria-hidden="true" />
      )
    }
  </div>

  <div class="card__text">
    <ProjectMeta studio={studio} role={role} years={years} />
    <div class="card__titlerow">
      <h2 class="t-card-title card__title">{title}</h2>
      {
        disciplines.length > 0 && (
          <div class="card__chips">
            {disciplines.map((d) => (
              <span class="chip">{d}</span>
            ))}
          </div>
        )
      }
    </div>
  </div>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4); /* 32px between cover and text */
    border-radius: var(--radius-image);
  }

  .card__image {
    position: relative;
    width: 100%;
    aspect-ratio: 1080 / 660; /* the cover frame, from Figma (~1.64:1) */
    border-radius: var(--radius-image);
    overflow: hidden;
    background: var(--color-divider);
  }
  .card__image :global(img) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .card__placeholder {
    position: absolute;
    inset: 0;
    background: var(--color-divider);
  }

  .card__text {
    display: flex;
    flex-direction: column;
    gap: var(--space-1); /* 8px between meta row and title row */
  }
  .card__titlerow {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }
  .card__title {
    margin: 0;
  }
  .card__chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
  }

  /* Mobile: stack the title above the chips. */
  @media (max-width: 767px) {
    .card__titlerow {
      align-items: flex-start;
      flex-direction: column;
      gap: 12px;
    }
  }
</style>
