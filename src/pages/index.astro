---
// HOME — the gallery. It builds itself from the project folders, so you never
// edit this file to add work: just add a project folder and push.
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Footer from '../components/Footer.astro';
import { getSortedProjects, slugForEntry } from '../lib/projects';
import { site } from '../data/site';

const projects = await getSortedProjects();
---

<BaseLayout title="Yael Issacharov / Portfolio">
  <main>
    <header class="hero">
      <h1 class="hero__title">
        <span class="t-h1">Yael Issacharov</span>
        <span class="t-h1-accent">Portfolio</span>
      </h1>
      <p class="hero__intro">
        {
          site.heroIntro.map((segment, i) => (
            <>
              {i > 0 && <span class="hero__sep" aria-hidden="true"></span>}
              <span class="hero__seg">{segment}</span>
            </>
          ))
        }
      </p>
    </header>

    <section class="gallery" aria-label="Selected work">
      {
        projects.map((p) => (
          <ProjectCard
            slug={slugForEntry(p)}
            title={p.data.title}
            disciplines={p.data.disciplines}
            studio={p.data.studio}
            role={p.data.role}
            years={p.data.years}
            thumbnail={p.data.thumbnail}
            featured={p.data.featured}
          />
        ))
      }
    </section>

    <Footer />
  </main>
</BaseLayout>

<style>
  .hero {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: var(--space-9) var(--pad-gallery) var(--space-7);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-6);
  }
  .hero__title {
    display: flex;
    flex-direction: column;
    width: 100%;
  }
  .hero__intro {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    column-gap: 18px;
    row-gap: 6px;
    width: 100%;
  }
  .hero__seg {
    font-family: var(--font-display);
    font-size: 36px;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }
  .hero__sep {
    width: 15px;
    height: 15px;
    background: var(--color-text);
    flex-shrink: 0;
  }
  @media (max-width: 767px) {
    .hero__seg {
      font-size: 24px;
    }
    .hero__sep {
      width: 11px;
      height: 11px;
    }
  }

  .gallery {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--pad-gallery);
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: var(--space-6);
    row-gap: var(--space-7);
  }
  /* Featured projects span the full width of the grid (desktop). */
  .gallery :global(.card--featured) {
    grid-column: 1 / -1;
  }

  /* Tablet + mobile: a single column. */
  @media (max-width: 1023px) {
    .gallery {
      grid-template-columns: 1fr;
    }
  }
</style>
